# ─────────────────────────────────────────────────────────────────────────────
# Project Zenith — frontend environment template. Copy to `.env.local`.
# ─────────────────────────────────────────────────────────────────────────────

# Cesium ion access token. Required for high-res imagery / terrain tiles.
# Get a free token at https://ion.cesium.com/tokens
# If omitted, CesiumGlobe falls back to the bundled offline natural-earth imagery.
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# Base URL of the backend aggregation gateway.
#   Real data:  http://localhost:8000   (run the backend: cd backend && npm run dev)
#   Offline:    leave blank             (uses the in-repo mock service layer)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# "live" routes through the backend (with automatic mock fallback on any failure,
# so the UI never breaks). "mock" forces the fully-offline deterministic demo.
NEXT_PUBLIC_DATA_SOURCE=live
